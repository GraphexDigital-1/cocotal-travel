---
interface Props {
  title?: string
  description?: string
}
const {
  title = 'Cocotal Travel | Hoteles y Excursiones en Punta Cana',
  description = 'Agencia de viajes con sede en Punta Cana. Reserva tu hotel todo incluido y las mejores excursiones al mejor precio. Atención personalizada 24/7.',
} = Astro.props
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/jpeg" href="/logo.jpg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <!-- Init dark mode before paint to avoid flash -->
    <script is:inline>
      ;(function () {
        const dark = localStorage.getItem('theme') === 'dark'
        if (dark) document.documentElement.classList.add('dark')
        const lang = localStorage.getItem('lang') || 'es'
        document.documentElement.lang = lang
      })()
    </script>
    <style>
      html { scroll-behavior: smooth; }
      .scrollbar-hide::-webkit-scrollbar { display: none; }
      .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
    </style>
  </head>
  <body class="bg-slate-50 dark:bg-slate-900 text-slate-900 dark:text-slate-100 font-sans antialiased transition-colors duration-300">
    <slot />

    <!-- i18n runtime -->
    <script>
      import { t, type Lang } from '../i18n/translations'

      function applyLang(lang: Lang) {
        document.documentElement.lang = lang
        localStorage.setItem('lang', lang)
        document.querySelectorAll<HTMLElement>('[data-i18n]').forEach(el => {
          const key = el.dataset.i18n as keyof (typeof t)['es']
          const val = t[lang][key]
          if (val !== undefined) {
            if (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') {
              ;(el as HTMLInputElement).placeholder = val
            } else {
              el.textContent = val
            }
          }
        })
        // Update lang toggle button label
        document.querySelectorAll<HTMLElement>('[data-lang-label]').forEach(el => {
          el.textContent = lang === 'es' ? 'EN' : 'ES'
        })
        // Notify components with bilingual data attributes
        document.dispatchEvent(new CustomEvent('langChange', { detail: lang }))
      }

      function toggleLang() {
        const current = (localStorage.getItem('lang') || 'es') as Lang
        applyLang(current === 'es' ? 'en' : 'es')
      }

      const moonSvg = `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>`
      const sunSvg = `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>`

      function toggleDark() {
        const isDark = document.documentElement.classList.toggle('dark')
        localStorage.setItem('theme', isDark ? 'dark' : 'light')
        document.querySelectorAll<HTMLElement>('[data-dark-icon]').forEach(el => {
          el.innerHTML = isDark ? sunSvg : moonSvg
        })
      }

      // Expose globally
      ;(window as any).toggleLang = toggleLang
      ;(window as any).toggleDark = toggleDark

      // Apply saved lang on load
      document.addEventListener('DOMContentLoaded', () => {
        const lang = (localStorage.getItem('lang') || 'es') as Lang
        applyLang(lang)
        const isDark = document.documentElement.classList.contains('dark')
        document.querySelectorAll<HTMLElement>('[data-dark-icon]').forEach(el => {
          el.innerHTML = isDark ? sunSvg : moonSvg
        })
      })
    </script>
  </body>
</html>
