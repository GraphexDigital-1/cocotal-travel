---
---
<header id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 flex items-center justify-between h-14 sm:h-16">

    <!-- Logo -->
    <a href="#inicio" class="flex items-center gap-2 shrink-0">
      <img src="/logo.jpg" alt="Cocotal Travel" class="h-9 w-9 sm:h-10 sm:w-10 rounded-full object-cover border-2 border-white/30" />
      <span class="hidden sm:block font-black text-white text-sm tracking-tight nav-brand-text">Cocotal Travel</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-5">
      {([
        ['#hoteles',      'nav_hotels'],
        ['#excursiones',  'nav_excursions'],
        ['#nosotros',     'nav_about'],
        ['#testimonios',  'nav_testimonials'],
      ] as [string, string][]).map(([href, key]) => (
        <a
          href={href}
          data-i18n={key}
          class="text-white/90 hover:text-white font-black text-[11px] uppercase tracking-widest transition-colors nav-link"
        >
          Hoteles
        </a>
      ))}
    </nav>

    <!-- Controls -->
    <div class="flex items-center gap-2">
      <!-- Dark mode toggle -->
      <button
        onclick="toggleDark()"
        class="flex items-center justify-center w-8 h-8 sm:w-9 sm:h-9 bg-white/15 hover:bg-white/25 border border-white/20 rounded-xl transition-all active:scale-95 text-sm nav-control"
        aria-label="Toggle dark mode"
      >
        <span data-dark-icon>🌙</span>
      </button>

      <!-- Language toggle -->
      <button
        onclick="toggleLang()"
        class="flex items-center justify-center h-8 px-3 sm:h-9 bg-white/15 hover:bg-white/25 border border-white/20 rounded-xl text-[10px] font-black text-white uppercase tracking-widest transition-all active:scale-95 nav-control"
        aria-label="Toggle language"
      >
        <span data-lang-label>EN</span>
      </button>

      <!-- CTA -->
      <a
        href="https://wa.me/18097654321?text=Hola%2C%20quiero%20información%20sobre%20paquetes%20de%20viaje"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden sm:flex items-center gap-1.5 bg-brand-orange hover:bg-brand-orange-dark text-white px-3 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all active:scale-95"
      >
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        <span data-i18n="nav_cta">Cotizar ahora</span>
      </a>
    </div>
  </div>
</header>

<script>
  const navbar = document.getElementById('navbar')!
  const links = navbar.querySelectorAll<HTMLElement>('.nav-link')
  const brand = navbar.querySelector<HTMLElement>('.nav-brand-text')
  const controls = navbar.querySelectorAll<HTMLElement>('.nav-control')

  function updateNavbar() {
    const scrolled = window.scrollY > 60
    if (scrolled) {
      navbar.classList.add('bg-white/95', 'dark:bg-slate-900/95', 'backdrop-blur-md', 'shadow-md', 'border-b', 'border-slate-200', 'dark:border-slate-700')
      links.forEach(l => { l.classList.remove('text-white/90'); l.classList.add('text-slate-700', 'dark:text-slate-200') })
      if (brand) { brand.classList.remove('text-white'); brand.classList.add('text-slate-900', 'dark:text-white') }
      controls.forEach(c => { c.classList.remove('bg-white/15', 'hover:bg-white/25', 'border-white/20', 'text-white'); c.classList.add('bg-slate-100', 'dark:bg-slate-800', 'hover:bg-slate-200', 'dark:hover:bg-slate-700', 'border-slate-200', 'dark:border-slate-600', 'text-slate-700', 'dark:text-slate-200') })
    } else {
      navbar.classList.remove('bg-white/95', 'dark:bg-slate-900/95', 'backdrop-blur-md', 'shadow-md', 'border-b', 'border-slate-200', 'dark:border-slate-700')
      links.forEach(l => { l.classList.add('text-white/90'); l.classList.remove('text-slate-700', 'dark:text-slate-200') })
      if (brand) { brand.classList.add('text-white'); brand.classList.remove('text-slate-900', 'dark:text-white') }
      controls.forEach(c => { c.classList.add('bg-white/15', 'hover:bg-white/25', 'border-white/20', 'text-white'); c.classList.remove('bg-slate-100', 'dark:bg-slate-800', 'hover:bg-slate-200', 'dark:hover:bg-slate-700', 'border-slate-200', 'dark:border-slate-600', 'text-slate-700', 'dark:text-slate-200') })
    }
  }

  window.addEventListener('scroll', updateNavbar)
  updateNavbar()
</script>
