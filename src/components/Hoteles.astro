---
const hoteles = [
  {
    nombre: 'Hard Rock Hotel & Casino',
    categoria_es: '5 Estrellas · Todo Incluido',
    categoria_en: '5 Stars · All Inclusive',
    desc_es: 'El resort más icónico de Punta Cana. Casino, spa de lujo, playa privada y entretenimiento de clase mundial.',
    desc_en: "Punta Cana's most iconic resort. Casino, luxury spa, private beach, and world-class entertainment.",
    precio_es: 'Desde $180/noche',
    precio_en: 'From $180/night',
    rating: '4.8',
    imagen: 'https://images.unsplash.com/photo-1582719478250-c89cae4dc85b?w=800&q=80',
    tags: ['Casino', 'Spa', 'Playa Privada'],
    tags_en: ['Casino', 'Spa', 'Private Beach'],
  },
  {
    nombre: 'Barceló Bávaro Beach',
    categoria_es: '5 Estrellas · Todo Incluido',
    categoria_en: '5 Stars · All Inclusive',
    desc_es: 'Frente a la famosa Playa de Bávaro, con 7 piscinas, shows nocturnos y restaurantes temáticos.',
    desc_en: 'Overlooking the famous Bávaro Beach, with 7 pools, evening shows and themed restaurants.',
    precio_es: 'Desde $140/noche',
    precio_en: 'From $140/night',
    rating: '4.7',
    imagen: 'https://images.unsplash.com/photo-1520250497591-112f2f40a3f4?w=800&q=80',
    tags: ['Playa Bávaro', '7 Piscinas', 'Shows'],
    tags_en: ['Bávaro Beach', '7 Pools', 'Shows'],
  },
  {
    nombre: 'Iberostar Dominicana',
    categoria_es: '4 Estrellas · Todo Incluido',
    categoria_en: '4 Stars · All Inclusive',
    desc_es: 'Excelente relación calidad-precio. Directo al mar, gastronomía internacional y actividades para toda la familia.',
    desc_en: 'Excellent value for money. Beachfront, international cuisine and activities for the whole family.',
    precio_es: 'Desde $95/noche',
    precio_en: 'From $95/night',
    rating: '4.6',
    imagen: 'https://images.unsplash.com/photo-1571896349842-33c89424de2d?w=800&q=80',
    tags: ['Familiar', 'Gastronomía', 'Actividades'],
    tags_en: ['Family', 'Gastronomy', 'Activities'],
  },
  {
    nombre: 'Royalton Splash',
    categoria_es: '5 Estrellas · Todo Incluido',
    categoria_en: '5 Stars · All Inclusive',
    desc_es: 'Parque acuático integrado, suites con bañera de hidromasaje y servicio Diamond Club exclusivo.',
    desc_en: 'Integrated water park, suites with hot tubs and exclusive Diamond Club service.',
    precio_es: 'Desde $160/noche',
    precio_en: 'From $160/night',
    rating: '4.7',
    imagen: 'https://images.unsplash.com/photo-1540541338537-1220059a7f56?w=800&q=80',
    tags: ['Parque Acuático', 'Suites', 'Diamond Club'],
    tags_en: ['Water Park', 'Suites', 'Diamond Club'],
  },
  {
    nombre: 'Majestic Elegance',
    categoria_es: '5 Estrellas · Solo Adultos',
    categoria_en: '5 Stars · Adults Only',
    desc_es: 'Ambiente romántico exclusivo para adultos. Suites premium, infinity pools y acceso a playa privada.',
    desc_en: 'Exclusive romantic atmosphere for adults. Premium suites, infinity pools and private beach access.',
    precio_es: 'Desde $175/noche',
    precio_en: 'From $175/night',
    rating: '4.9',
    imagen: 'https://images.unsplash.com/photo-1611892440504-42a792e24d32?w=800&q=80',
    tags: ['Solo Adultos', 'Romántico', 'Infinity Pool'],
    tags_en: ['Adults Only', 'Romantic', 'Infinity Pool'],
  },
  {
    nombre: 'Sirenis Cocotal Beach',
    categoria_es: '5 Estrellas · Todo Incluido',
    categoria_en: '5 Stars · All Inclusive',
    desc_es: 'En la zona de Uvero Alto, más tranquila y exclusiva. Rodeado de naturaleza tropical con acceso a playa.',
    desc_en: 'In the quieter Uvero Alto area. Surrounded by tropical nature with beach access.',
    precio_es: 'Desde $120/noche',
    precio_en: 'From $120/night',
    rating: '4.5',
    imagen: 'https://images.unsplash.com/photo-1445019980597-93fa8acb246c?w=800&q=80',
    tags: ['Cocotal', 'Tranquilo', 'Naturaleza'],
    tags_en: ['Cocotal', 'Peaceful', 'Nature'],
  },
]
---

<section id="hoteles" class="py-14 sm:py-20 bg-slate-50 dark:bg-slate-900 transition-colors duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <!-- Header -->
    <div class="flex flex-col items-center text-center mb-8 sm:mb-12 gap-2 sm:gap-3">
      <div class="flex items-center gap-3">
        <div class="h-px w-10 bg-brand-orange"></div>
        <span data-i18n="hotels_tag" class="text-[10px] font-black uppercase tracking-widest text-brand-orange">Alojamiento</span>
        <div class="h-px w-10 bg-brand-orange"></div>
      </div>
      <h2 data-i18n="hotels_title" class="text-3xl sm:text-4xl md:text-5xl font-black text-slate-900 dark:text-white tracking-tight">
        Hoteles Destacados
      </h2>
      <p data-i18n="hotels_subtitle" class="text-slate-500 dark:text-slate-400 font-medium max-w-xl text-sm sm:text-base">
        Los mejores resorts todo incluido de Punta Cana al mejor precio, con atención personalizada de principio a fin.
      </p>
    </div>

    <!-- Grid — mobile: 1 col, md: 2, xl: 3 -->
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5 sm:gap-6">
      {hoteles.map(({ nombre, categoria_es, categoria_en, desc_es, desc_en, precio_es, precio_en, rating, imagen, tags, tags_en }) => (
        <div class="bg-white dark:bg-slate-800 rounded-2xl sm:rounded-3xl shadow-md overflow-hidden border border-slate-200 dark:border-slate-700 hover:shadow-xl transition-all duration-300 group flex flex-col">
          <!-- Image -->
          <div class="relative h-44 sm:h-52 overflow-hidden shrink-0">
            <img
              src={imagen}
              alt={nombre}
              loading="lazy"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
            <div class="absolute top-3 right-3 flex items-center gap-1 bg-black/40 backdrop-blur-sm px-2 py-1 rounded-xl">
              <svg class="w-3 h-3 text-amber-400 fill-amber-400" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <span class="text-white font-black text-[10px]">{rating}</span>
            </div>
            <div class="absolute bottom-3 left-3">
              <span
                data-cat-es={categoria_es}
                data-cat-en={categoria_en}
                class="hotel-cat bg-brand-blue/90 text-white text-[9px] font-black uppercase tracking-widest px-2 py-1 rounded-full"
              >
                {categoria_es}
              </span>
            </div>
          </div>

          <!-- Content -->
          <div class="p-4 sm:p-6 flex flex-col gap-3 flex-1">
            <h3 class="text-base sm:text-lg font-black text-slate-900 dark:text-white leading-tight">{nombre}</h3>
            <p
              data-desc-es={desc_es}
              data-desc-en={desc_en}
              class="hotel-desc text-slate-500 dark:text-slate-400 text-xs sm:text-sm font-medium leading-relaxed flex-1"
            >
              {desc_es}
            </p>

            <div class="flex flex-wrap gap-1.5">
              {tags.map((tag, i) => (
                <span
                  data-tag-es={tag}
                  data-tag-en={tags_en[i]}
                  class="hotel-tag bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 text-[9px] font-black uppercase tracking-wider px-2 py-1 rounded-lg border border-slate-200 dark:border-slate-600"
                >
                  {tag}
                </span>
              ))}
            </div>

            <div class="flex items-center justify-between mt-1 pt-3 border-t border-slate-100 dark:border-slate-700">
              <span
                data-price-es={precio_es}
                data-price-en={precio_en}
                class="hotel-price text-brand-orange font-black text-sm sm:text-base"
              >
                {precio_es}
              </span>
              <a
                href={`https://wa.me/18097654321?text=Hola%2C%20me%20interesa%20el%20hotel%20${encodeURIComponent(nombre)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-1.5 bg-brand-orange hover:bg-brand-orange-dark text-white px-3 sm:px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-wider transition-all active:scale-95"
              >
                <span data-i18n="hotels_quote">Cotizar</span>
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="flex justify-center mt-8 sm:mt-10">
      <a
        href="https://wa.me/18097654321?text=Hola%2C%20quiero%20ver%20m%C3%A1s%20opciones%20de%20hoteles"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 border-2 border-brand-blue text-brand-blue hover:bg-brand-blue hover:text-white dark:border-brand-blue dark:text-brand-blue dark:hover:text-white px-6 sm:px-8 py-3 rounded-2xl font-black text-sm transition-all active:scale-95"
      >
        <span data-i18n="hotels_viewall">Ver todos los hoteles disponibles</span>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<script>
  // Update hotel-specific bilingual data (not covered by generic data-i18n)
  function updateHotels(lang: string) {
    document.querySelectorAll<HTMLElement>('.hotel-cat').forEach(el => {
      el.textContent = lang === 'en' ? el.dataset.catEn! : el.dataset.catEs!
    })
    document.querySelectorAll<HTMLElement>('.hotel-desc').forEach(el => {
      el.textContent = lang === 'en' ? el.dataset.descEn! : el.dataset.descEs!
    })
    document.querySelectorAll<HTMLElement>('.hotel-tag').forEach(el => {
      el.textContent = lang === 'en' ? el.dataset.tagEn! : el.dataset.tagEs!
    })
    document.querySelectorAll<HTMLElement>('.hotel-price').forEach(el => {
      el.textContent = lang === 'en' ? el.dataset.priceEn! : el.dataset.priceEs!
    })
  }

  document.addEventListener('DOMContentLoaded', () => {
    updateHotels(localStorage.getItem('lang') || 'es')
  })

  // Listen for custom lang-change event dispatched by Layout
  document.addEventListener('langChange', (e: Event) => {
    updateHotels((e as CustomEvent).detail)
  })
</script>
