---
const stats = [
  { value: '+500', key: 'stat_clients', fallback: 'Clientes Felices', icon: '😊' },
  { value: '+50',  key: 'stat_hotels',  fallback: 'Hoteles Aliados',  icon: '🏨' },
  { value: '+20',  key: 'stat_excursions', fallback: 'Excursiones',   icon: '🚤' },
  { value: '10+',  key: 'stat_years',   fallback: 'Años de Experiencia', icon: '🌴' },
]
---
<section class="py-8 sm:py-10 bg-white dark:bg-slate-950 border-b border-slate-100 dark:border-slate-800 transition-colors duration-300">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 grid grid-cols-2 md:grid-cols-4 gap-5 sm:gap-6">
    {stats.map(({ value, key, fallback, icon }) => (
      <div class="flex flex-col items-center gap-1 text-center">
        <span class="text-xl sm:text-2xl">{icon}</span>
        <span class="text-2xl sm:text-3xl font-black text-brand-blue">{value}</span>
        <span data-i18n={key} class="text-[9px] sm:text-[10px] font-black uppercase tracking-widest text-slate-400 dark:text-slate-500">
          {fallback}
        </span>
      </div>
    ))}
  </div>
</section>
