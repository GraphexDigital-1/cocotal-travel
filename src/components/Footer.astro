---
const services = [
  ['footer_s1','Hoteles Todo Incluido'],
  ['footer_s2','Excursiones y Tours'],
  ['footer_s3','Traslados Aeropuerto'],
  ['footer_s4','Paquetes Luna de Miel'],
  ['footer_s5','Vacaciones Familiares'],
  ['footer_s6','Grupos y Eventos'],
]
---

<footer class="bg-slate-950 dark:bg-black text-white py-10 sm:py-14 transition-colors duration-300">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8 sm:gap-10 mb-8 sm:mb-10">

      <!-- Brand -->
      <div class="flex flex-col gap-4">
        <div class="flex items-center gap-3">
          <img src="/logo.jpg" alt="Cocotal Travel" class="h-11 w-11 sm:h-12 sm:w-12 rounded-full object-cover border-2 border-brand-orange/40" />
          <div>
            <div class="font-black text-base sm:text-lg text-white leading-none">Cocotal Travel</div>
            <div class="text-[10px] font-black uppercase tracking-widest text-slate-400 mt-0.5">Punta Cana · R.D.</div>
          </div>
        </div>
        <p data-i18n="footer_desc" class="text-slate-400 text-sm font-medium leading-relaxed">
          Agencia de viajes con sede en Punta Cana. Tu aliado de confianza para hoteles y excursiones en el Caribe.
        </p>
        <div class="flex gap-2 sm:gap-3">
          <a href="https://wa.me/18097654321" target="_blank" rel="noopener noreferrer"
            class="flex items-center justify-center w-9 h-9 bg-green-500/20 hover:bg-green-500 border border-green-500/30 text-green-400 hover:text-white rounded-xl transition-all">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </a>
          <a href="https://instagram.com" target="_blank" rel="noopener noreferrer"
            class="flex items-center justify-center w-9 h-9 bg-pink-500/20 hover:bg-pink-500 border border-pink-500/30 text-pink-400 hover:text-white rounded-xl transition-all">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="https://facebook.com" target="_blank" rel="noopener noreferrer"
            class="flex items-center justify-center w-9 h-9 bg-blue-500/20 hover:bg-blue-500 border border-blue-500/30 text-blue-400 hover:text-white rounded-xl transition-all">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h4 data-i18n="footer_services" class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-4 sm:mb-5">Servicios</h4>
        <ul class="space-y-2.5 sm:space-y-3">
          {services.map(([key, fallback]) => (
            <li>
              <a href="#contacto" class="text-slate-400 hover:text-white text-sm font-medium transition-colors flex items-center gap-2">
                <span class="w-1 h-1 bg-brand-orange rounded-full shrink-0"></span>
                <span data-i18n={key}>{fallback}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 data-i18n="footer_contact" class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-4 sm:mb-5">Contacto</h4>
        <ul class="space-y-3 sm:space-y-4">
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-brand-orange mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span class="text-slate-400 text-sm font-medium">Punta Cana, La Altagracia<br/>República Dominicana</span>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-4 h-4 text-brand-orange shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            <a href="https://wa.me/18097654321" class="text-slate-400 hover:text-white text-sm font-medium transition-colors">+1 (809) 765-4321</a>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-4 h-4 text-brand-orange shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            <a href="mailto:info@cocotaltravel.com" class="text-slate-400 hover:text-white text-sm font-medium transition-colors">info@cocotaltravel.com</a>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-4 h-4 text-brand-orange shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span data-i18n="footer_hours" class="text-slate-400 text-sm font-medium">Lun – Dom · 8am – 9pm</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-slate-800 pt-5 sm:pt-6 flex flex-col sm:flex-row items-center justify-between gap-2 sm:gap-3">
      <span data-i18n="footer_rights" class="text-slate-500 text-xs font-medium text-center sm:text-left">
        © 2025 Cocotal Travel · Todos los derechos reservados
      </span>
      <span data-i18n="footer_location" class="text-slate-600 text-xs font-medium">
        Punta Cana · República Dominicana
      </span>
    </div>
  </div>
</footer>

<!-- Floating WhatsApp -->
<a
  href="https://wa.me/18097654321?text=Hola%20Cocotal%20Travel%2C%20quiero%20información%20sobre%20viajes"
  target="_blank" rel="noopener noreferrer"
  class="fixed bottom-5 right-4 sm:bottom-6 sm:right-6 z-50 flex items-center gap-2 bg-green-500 hover:bg-green-600 text-white px-3 sm:px-4 py-2.5 sm:py-3 rounded-xl sm:rounded-2xl shadow-xl shadow-green-900/30 font-black text-sm transition-all hover:scale-105 active:scale-95"
>
  <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 24 24">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
  </svg>
  <span data-i18n="wa_float" class="hidden sm:inline">¡Chatea con nosotros!</span>
</a>
