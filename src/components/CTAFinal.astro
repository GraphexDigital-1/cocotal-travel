---
---
<section id="contacto" class="py-14 sm:py-20 bg-slate-900 dark:bg-slate-950 relative overflow-hidden">
  <div class="absolute inset-0 opacity-10 bg-cover bg-center"
    style="background-image: url('https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=1200&q=60')"></div>
  <div class="absolute inset-0 bg-gradient-to-br from-slate-900/90 via-slate-900/80 to-brand-blue/30"></div>

  <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 grid md:grid-cols-2 gap-8 sm:gap-12 items-center">
    <!-- Left -->
    <div class="flex flex-col gap-4 sm:gap-5">
      <div class="flex items-center gap-3">
        <div class="h-px w-10 bg-brand-orange"></div>
        <span data-i18n="cta_tag" class="text-[10px] font-black uppercase tracking-widest text-brand-orange">Empieza hoy</span>
      </div>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-black text-white tracking-tight leading-tight">
        <span data-i18n="cta_title">¿Cuándo Viajamos a Punta Cana?</span>
      </h2>
      <p data-i18n="cta_subtitle" class="text-slate-300 font-medium leading-relaxed text-sm sm:text-base">
        Cuéntanos tus fechas, presupuesto y lo que buscas. En menos de 30 minutos tendrás tu cotización personalizada sin compromiso.
      </p>
      <div class="flex flex-col gap-2.5">
        {[
          ['cta_check1', 'Cotización gratuita y sin compromiso'],
          ['cta_check2', 'Confirmación inmediata con voucher'],
          ['cta_check3', 'Soporte 24/7 durante todo tu viaje'],
          ['cta_check4', 'Los mejores precios de Punta Cana'],
        ].map(([key, text]) => (
          <div class="flex items-center gap-2.5">
            <div class="w-5 h-5 rounded-full bg-brand-orange/25 flex items-center justify-center shrink-0">
              <svg class="w-3 h-3 text-brand-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <span data-i18n={key} class="text-slate-300 text-xs sm:text-sm font-medium">{text}</span>
          </div>
        ))}
      </div>
      <a
        href="https://wa.me/18097654321?text=Hola%20Cocotal%20Travel%2C%20quiero%20cotizar%20mi%20viaje%20a%20Punta%20Cana"
        target="_blank" rel="noopener noreferrer"
        class="flex items-center justify-center gap-3 bg-green-500 hover:bg-green-600 active:scale-95 transition-all text-white px-6 sm:px-8 py-4 sm:py-5 rounded-2xl font-black text-sm sm:text-base shadow-xl shadow-green-900/30"
      >
        <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        <span data-i18n="cta_wa">Escribir por WhatsApp ahora</span>
      </a>
    </div>

    <!-- Right: Form -->
    <div class="bg-white/5 backdrop-blur-md border border-white/10 rounded-2xl sm:rounded-3xl p-5 sm:p-8">
      <h3 data-i18n="form_title" class="text-white font-black text-lg sm:text-xl mb-5 sm:mb-6">Solicita tu cotización</h3>
      <form id="cotizacion-form" class="flex flex-col gap-3 sm:gap-4">
        <div class="grid grid-cols-2 gap-2 sm:gap-3">
          <div class="flex flex-col gap-1.5">
            <label data-i18n="form_name" class="text-[10px] font-black uppercase tracking-widest text-slate-400">Nombre</label>
            <input type="text" name="nombre" required data-i18n-ph="form_name_ph"
              placeholder="Tu nombre"
              class="bg-white/10 border border-white/20 text-white placeholder-white/30 rounded-xl px-3 py-2.5 text-sm focus:border-brand-orange outline-none transition-colors" />
          </div>
          <div class="flex flex-col gap-1.5">
            <label data-i18n="form_phone" class="text-[10px] font-black uppercase tracking-widest text-slate-400">WhatsApp</label>
            <input type="tel" name="telefono" required data-i18n-ph="form_phone_ph"
              placeholder="+1 809..."
              class="bg-white/10 border border-white/20 text-white placeholder-white/30 rounded-xl px-3 py-2.5 text-sm focus:border-brand-orange outline-none transition-colors" />
          </div>
        </div>

        <div class="flex flex-col gap-1.5">
          <label data-i18n="form_service" class="text-[10px] font-black uppercase tracking-widest text-slate-400">¿Qué buscas?</label>
          <select name="servicio"
            class="bg-white/10 border border-white/20 text-white rounded-xl px-3 py-2.5 text-sm focus:border-brand-orange outline-none transition-colors appearance-none">
            <option value="" class="bg-slate-800" data-i18n="form_service_ph">Selecciona un servicio</option>
            <option value="hotel" class="bg-slate-800" data-i18n="form_s1">Hotel Todo Incluido</option>
            <option value="excursion" class="bg-slate-800" data-i18n="form_s2">Excursiones</option>
            <option value="paquete" class="bg-slate-800" data-i18n="form_s3">Paquete Completo</option>
            <option value="luna" class="bg-slate-800" data-i18n="form_s4">Luna de Miel</option>
            <option value="familia" class="bg-slate-800" data-i18n="form_s5">Vacaciones Familiares</option>
          </select>
        </div>

        <div class="grid grid-cols-2 gap-2 sm:gap-3">
          <div class="flex flex-col gap-1.5">
            <label data-i18n="form_arrival" class="text-[10px] font-black uppercase tracking-widest text-slate-400">Fecha de llegada</label>
            <input type="date" name="fecha_llegada"
              class="bg-white/10 border border-white/20 text-white rounded-xl px-3 py-2.5 text-sm focus:border-brand-orange outline-none transition-colors" />
          </div>
          <div class="flex flex-col gap-1.5">
            <label data-i18n="form_nights" class="text-[10px] font-black uppercase tracking-widest text-slate-400">Noches</label>
            <select name="noches"
              class="bg-white/10 border border-white/20 text-white rounded-xl px-3 py-2.5 text-sm focus:border-brand-orange outline-none transition-colors">
              <option class="bg-slate-800" data-i18n="form_n1">3 noches</option>
              <option class="bg-slate-800" data-i18n="form_n2">5 noches</option>
              <option class="bg-slate-800" data-i18n="form_n3">7 noches</option>
              <option class="bg-slate-800" data-i18n="form_n4">10 noches</option>
              <option class="bg-slate-800" data-i18n="form_n5">+10 noches</option>
            </select>
          </div>
        </div>

        <div class="flex flex-col gap-1.5">
          <label data-i18n="form_msg" class="text-[10px] font-black uppercase tracking-widest text-slate-400">Mensaje adicional</label>
          <textarea name="mensaje" rows={3} data-i18n-ph="form_msg_ph"
            placeholder="Número de personas, preferencias, presupuesto aproximado..."
            class="bg-white/10 border border-white/20 text-white placeholder-white/30 rounded-xl px-3 py-2.5 text-sm focus:border-brand-orange outline-none resize-none transition-colors"></textarea>
        </div>

        <button type="submit"
          class="flex items-center justify-center gap-2 bg-brand-orange hover:bg-brand-orange-dark active:scale-95 transition-all text-white px-6 py-3.5 sm:py-4 rounded-xl font-black text-sm w-full">
          <span data-i18n="form_submit">Enviar Solicitud de Cotización</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
          </svg>
        </button>
      </form>
    </div>
  </div>
</section>

<script>
  import { t, type Lang } from '../i18n/translations'

  document.getElementById('cotizacion-form')!.addEventListener('submit', (e) => {
    e.preventDefault()
    const lang = (localStorage.getItem('lang') || 'es') as Lang
    const form = e.target as HTMLFormElement
    const data = new FormData(form)
    const nombre = data.get('nombre') as string
    const telefono = data.get('telefono') as string
    const servicio = data.get('servicio') as string
    const fecha = data.get('fecha_llegada') as string
    const noches = data.get('noches') as string
    const mensaje = data.get('mensaje') as string

    const txt = lang === 'en'
      ? `Hello Cocotal Travel! 🌴\n\n*Quote Request*\n👤 Name: ${nombre}\n📱 Phone: ${telefono}\n🏖️ Service: ${servicio}\n📅 Arrival: ${fecha}\n🌙 Nights: ${noches}\n💬 Message: ${mensaje}`
      : `Hola Cocotal Travel! 🌴\n\n*Solicitud de Cotización*\n👤 Nombre: ${nombre}\n📱 Teléfono: ${telefono}\n🏖️ Servicio: ${servicio}\n📅 Llegada: ${fecha}\n🌙 Noches: ${noches}\n💬 Mensaje: ${mensaje}`

    window.open(`https://wa.me/18097654321?text=${encodeURIComponent(txt)}`, '_blank')
  })

  // Placeholders are handled by the generic data-i18n system via Layout
</script>
