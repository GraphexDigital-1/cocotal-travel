---
---
<section
  id="inicio"
  class="relative min-h-screen flex items-center justify-center text-center text-white bg-cover bg-center overflow-hidden"
  style="background-image: url('https://images.unsplash.com/photo-1596394516093-501ba68a0ba6?w=1800&q=80')"
>
  <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/40 to-black/70"></div>
  <div class="absolute bottom-0 left-0 right-0 h-24 sm:h-32 bg-gradient-to-t from-slate-50 dark:from-slate-900 to-transparent"></div>

  <!-- Badge -->
  <div class="absolute top-[4.5rem] sm:top-20 left-1/2 -translate-x-1/2 z-10 w-max">
    <div class="flex items-center gap-2 bg-brand-orange/90 backdrop-blur-sm px-3 py-1.5 rounded-full">
      <span class="w-1.5 h-1.5 bg-white rounded-full animate-pulse"></span>
      <span data-i18n="hero_badge" class="text-[9px] sm:text-[10px] font-black uppercase tracking-widest whitespace-nowrap">
        Sede en Punta Cana · República Dominicana
      </span>
    </div>
  </div>

  <!-- Content -->
  <div class="relative z-10 px-4 sm:px-6 flex flex-col items-center gap-4 sm:gap-5 mt-14 sm:mt-10">
    <img
      src="/logo.jpg"
      alt="Cocotal Travel"
      class="w-20 h-20 sm:w-28 sm:h-28 rounded-full border-4 border-white/30 shadow-2xl object-cover"
    />

    <div class="flex items-center gap-3">
      <div class="h-px w-8 sm:w-12 bg-gradient-to-r from-transparent to-brand-orange/70"></div>
      <span data-i18n="hero_tag" class="text-[9px] sm:text-[10px] font-black uppercase tracking-[0.3em] text-orange-300">
        Tu agencia de confianza
      </span>
      <div class="h-px w-8 sm:w-12 bg-gradient-to-l from-transparent to-brand-orange/70"></div>
    </div>

    <h1
      class="text-4xl sm:text-5xl md:text-7xl font-black tracking-tight leading-none drop-shadow-xl whitespace-pre-line"
      style="background: linear-gradient(135deg, #ffffff 0%, #fed7aa 50%, #1B9BD1 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
      data-i18n="hero_title"
    >
      Punta Cana{'\n'}Como Nunca
    </h1>

    <p data-i18n="hero_subtitle" class="text-white/80 text-sm sm:text-base md:text-lg font-medium max-w-xl leading-relaxed">
      Hoteles todo incluido y excursiones inolvidables. Atención personalizada desde Punta Cana, precios directos sin intermediarios.
    </p>

    <!-- Stats pills -->
    <div class="flex items-center justify-center gap-2 flex-wrap mt-1">
      {[
        ['🏨', 'hero_stat1', '+50 Hoteles'],
        ['🚤', 'hero_stat2', '+20 Excursiones'],
        ['⭐', 'hero_stat3', '4.9 / 5 Rating'],
        ['🌴', 'hero_stat4', '10+ Años'],
      ].map(([icon, key, fallback]) => (
        <div class="flex items-center gap-1.5 bg-white/10 backdrop-blur-sm border border-white/20 px-2.5 py-1.5 rounded-full">
          <span class="text-xs sm:text-sm">{icon}</span>
          <span data-i18n={key} class="text-[9px] sm:text-[10px] font-black uppercase tracking-widest text-white/90">
            {fallback}
          </span>
        </div>
      ))}
    </div>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-3 mt-2 w-full sm:w-auto">
      <a
        href="https://wa.me/18097654321?text=Hola%2C%20quiero%20cotizar%20mi%20viaje%20a%20Punta%20Cana"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center justify-center gap-2 bg-green-500 hover:bg-green-600 active:scale-95 transition-all text-white px-6 sm:px-8 py-4 rounded-2xl font-black text-sm shadow-lg shadow-green-900/30"
      >
        <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        <span data-i18n="hero_cta_wa">Cotiza por WhatsApp</span>
      </a>
      <a
        href="#hoteles"
        class="flex items-center justify-center gap-2 bg-white/15 hover:bg-white/25 backdrop-blur-sm border border-white/30 active:scale-95 transition-all text-white px-6 sm:px-8 py-4 rounded-2xl font-black text-sm"
      >
        <span data-i18n="hero_cta_hotels">Ver Hoteles</span>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
        </svg>
      </a>
    </div>
  </div>

  <div class="absolute bottom-8 sm:bottom-10 left-1/2 -translate-x-1/2 z-10 animate-bounce">
    <svg class="w-5 h-5 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
    </svg>
  </div>
</section>
