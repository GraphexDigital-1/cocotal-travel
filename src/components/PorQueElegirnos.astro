---
const razones = [
  {
    iconSvg: `<svg class="w-5 h-5 text-brand-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
    title_key: 'why1_title', desc_key: 'why1_desc',
  },
  {
    iconSvg: `<svg class="w-5 h-5 text-brand-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"/></svg>`,
    title_key: 'why2_title', desc_key: 'why2_desc',
  },
  {
    iconSvg: `<svg class="w-5 h-5 text-brand-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>`,
    title_key: 'why3_title', desc_key: 'why3_desc',
  },
  {
    iconSvg: `<svg class="w-5 h-5 text-brand-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
    title_key: 'why4_title', desc_key: 'why4_desc',
  },
  {
    iconSvg: `<svg class="w-5 h-5 text-brand-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/></svg>`,
    title_key: 'why5_title', desc_key: 'why5_desc',
  },
  {
    iconSvg: `<svg class="w-5 h-5 text-brand-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>`,
    title_key: 'why6_title', desc_key: 'why6_desc',
  },
]

const fallbacks: Record<string, string> = {
  why1_title: 'Sede en Punta Cana',
  why1_desc: 'Estamos en Punta Cana. Conocemos cada hotel, playa y excursión de primera mano. Sin intermediarios, sin sorpresas.',
  why2_title: 'Precios Directos',
  why2_desc: 'Al trabajar directamente con hoteles y operadoras locales, te garantizamos los mejores precios del mercado.',
  why3_title: 'Atención 24/7',
  why3_desc: 'Antes, durante y después de tu viaje. Siempre disponibles por WhatsApp para resolver cualquier situación.',
  why4_title: 'Reserva 100% Segura',
  why4_desc: 'Confirmación inmediata por escrito. Tu reserva queda respaldada con voucher oficial desde el primer pago.',
  why5_title: 'Paquetes a Tu Medida',
  why5_desc: 'No hay dos viajes iguales. Armamos tu paquete según tu presupuesto, fechas y preferencias personales.',
  why6_title: 'Expertos Locales',
  why6_desc: 'Más de 10 años operando en Punta Cana. Sabemos exactamente qué funciona y qué no para cada tipo de viajero.',
}
---

<section id="nosotros" class="py-14 sm:py-20 bg-slate-50 dark:bg-slate-900 transition-colors duration-300">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <!-- Header -->
    <div class="flex flex-col items-center text-center mb-8 sm:mb-12 gap-2 sm:gap-3">
      <div class="flex items-center gap-3">
        <div class="h-px w-10 bg-brand-orange"></div>
        <span data-i18n="why_tag" class="text-[10px] font-semibold uppercase tracking-widest text-brand-orange">¿Por qué nosotros?</span>
        <div class="h-px w-10 bg-brand-orange"></div>
      </div>
      <h2 data-i18n="why_title" class="text-3xl sm:text-4xl md:text-5xl font-black text-slate-900 dark:text-white tracking-tight">
        Tu Viaje Perfecto, Garantizado
      </h2>
      <p data-i18n="why_subtitle" class="text-slate-500 dark:text-slate-400 font-medium max-w-lg text-sm sm:text-base">
        Somos más que una agencia. Somos tu contacto local en el paraíso dominicano.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4 sm:gap-5">
      {razones.map(({ iconSvg, title_key, desc_key }) => (
        <div class="bg-white dark:bg-slate-800 rounded-2xl sm:rounded-3xl p-5 sm:p-7 border border-slate-200 dark:border-slate-700 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-300">
          <div class="flex items-start gap-3 sm:gap-4">
            <div class="w-9 h-9 rounded-xl bg-brand-orange/10 dark:bg-brand-orange/15 flex items-center justify-center shrink-0 mt-0.5">
              <Fragment set:html={iconSvg} />
            </div>
            <div>
              <h3 data-i18n={title_key} class="font-bold text-slate-900 dark:text-white text-sm sm:text-base mb-1 sm:mb-2">
                {fallbacks[title_key]}
              </h3>
              <p data-i18n={desc_key} class="text-slate-500 dark:text-slate-400 text-xs sm:text-sm leading-relaxed">
                {fallbacks[desc_key]}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA Banner — clean dark, no gradient -->
    <div class="mt-10 sm:mt-12 bg-slate-900 dark:bg-slate-950 border border-slate-800 rounded-2xl sm:rounded-3xl p-6 sm:p-8 flex flex-col sm:flex-row items-center justify-between gap-5 sm:gap-6 text-white">
      <div class="text-center sm:text-left">
        <h3 data-i18n="why_banner_title" class="text-xl sm:text-2xl font-bold mb-1">¿Listo para tu próximo viaje?</h3>
        <p data-i18n="why_banner_sub" class="text-slate-400 text-sm">Recibe una cotización personalizada en menos de 30 minutos.</p>
      </div>
      <a
        href="https://wa.me/18097654321?text=Hola%2C%20quiero%20cotizar%20un%20paquete%20de%20viaje%20a%20Punta%20Cana"
        target="_blank" rel="noopener noreferrer"
        class="w-full sm:w-auto shrink-0 flex items-center justify-center gap-2 bg-brand-orange hover:bg-brand-orange-dark text-white px-6 sm:px-8 py-3 sm:py-4 rounded-xl font-bold text-sm transition-all active:scale-95"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        <span data-i18n="why_banner_cta">Cotizar gratis ahora</span>
      </a>
    </div>
  </div>
</section>
