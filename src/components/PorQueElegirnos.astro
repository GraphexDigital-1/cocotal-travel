---
const razones = [
  { icon: '📍', title_key: 'why1_title', desc_key: 'why1_desc' },
  { icon: '💰', title_key: 'why2_title', desc_key: 'why2_desc' },
  { icon: '📲', title_key: 'why3_title', desc_key: 'why3_desc' },
  { icon: '✅', title_key: 'why4_title', desc_key: 'why4_desc' },
  { icon: '🎯', title_key: 'why5_title', desc_key: 'why5_desc' },
  { icon: '🌴', title_key: 'why6_title', desc_key: 'why6_desc' },
]

const fallbacks: Record<string, string> = {
  why1_title: 'Sede en Punta Cana',
  why1_desc: 'Estamos en Punta Cana. Conocemos cada hotel, playa y excursión de primera mano. Sin intermediarios, sin sorpresas.',
  why2_title: 'Precios Directos',
  why2_desc: 'Al trabajar directamente con hoteles y operadoras locales, te garantizamos los mejores precios del mercado.',
  why3_title: 'Atención 24/7',
  why3_desc: 'Antes, durante y después de tu viaje. Siempre disponibles por WhatsApp para resolver cualquier situación.',
  why4_title: 'Reserva 100% Segura',
  why4_desc: 'Confirmación inmediata por escrito. Tu reserva queda respaldada con voucher oficial desde el primer pago.',
  why5_title: 'Paquetes a Tu Medida',
  why5_desc: 'No hay dos viajes iguales. Armamos tu paquete según tu presupuesto, fechas y preferencias personales.',
  why6_title: 'Expertos Locales',
  why6_desc: 'Más de 10 años operando en Punta Cana. Sabemos exactamente qué funciona y qué no para cada tipo de viajero.',
}
---

<section id="nosotros" class="py-14 sm:py-20 bg-slate-50 dark:bg-slate-900 transition-colors duration-300">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <!-- Header -->
    <div class="flex flex-col items-center text-center mb-8 sm:mb-12 gap-2 sm:gap-3">
      <div class="flex items-center gap-3">
        <div class="h-px w-10 bg-brand-orange"></div>
        <span data-i18n="why_tag" class="text-[10px] font-black uppercase tracking-widest text-brand-orange">¿Por qué nosotros?</span>
        <div class="h-px w-10 bg-brand-orange"></div>
      </div>
      <h2 data-i18n="why_title" class="text-3xl sm:text-4xl md:text-5xl font-black text-slate-900 dark:text-white tracking-tight">
        Tu Viaje Perfecto, Garantizado
      </h2>
      <p data-i18n="why_subtitle" class="text-slate-500 dark:text-slate-400 font-medium max-w-lg text-sm sm:text-base">
        Somos más que una agencia. Somos tu contacto local en el paraíso dominicano.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4 sm:gap-5">
      {razones.map(({ icon, title_key, desc_key }) => (
        <div class="bg-white dark:bg-slate-800 rounded-2xl sm:rounded-3xl p-5 sm:p-7 border border-slate-200 dark:border-slate-700 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300">
          <div class="flex items-start gap-3 sm:gap-4">
            <div class="text-2xl sm:text-3xl shrink-0 mt-0.5">{icon}</div>
            <div>
              <h3 data-i18n={title_key} class="font-black text-slate-900 dark:text-white text-sm sm:text-base mb-1 sm:mb-2">
                {fallbacks[title_key]}
              </h3>
              <p data-i18n={desc_key} class="text-slate-500 dark:text-slate-400 text-xs sm:text-sm font-medium leading-relaxed">
                {fallbacks[desc_key]}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Banner -->
    <div class="mt-10 sm:mt-12 bg-gradient-to-r from-brand-blue to-brand-orange rounded-2xl sm:rounded-3xl p-6 sm:p-8 flex flex-col sm:flex-row items-center justify-between gap-5 sm:gap-6 text-white">
      <div class="text-center sm:text-left">
        <h3 data-i18n="why_banner_title" class="text-xl sm:text-2xl font-black mb-1">¿Listo para tu próximo viaje?</h3>
        <p data-i18n="why_banner_sub" class="text-white/80 font-medium text-sm">Recibe una cotización personalizada en menos de 30 minutos.</p>
      </div>
      <a
        href="https://wa.me/18097654321?text=Hola%2C%20quiero%20cotizar%20un%20paquete%20de%20viaje%20a%20Punta%20Cana"
        target="_blank" rel="noopener noreferrer"
        class="w-full sm:w-auto shrink-0 flex items-center justify-center gap-2 bg-white text-brand-orange hover:bg-orange-50 px-6 sm:px-8 py-3 sm:py-4 rounded-2xl font-black text-sm transition-all active:scale-95 shadow-lg"
      >
        <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        <span data-i18n="why_banner_cta">Cotizar gratis ahora</span>
      </a>
    </div>
  </div>
</section>
